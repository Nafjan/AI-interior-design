{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        "npm install -g pnpm",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "commands": [
        "pnpm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "node_modules/.bin/next start -p ${PORT:-3000}"
  }
}
