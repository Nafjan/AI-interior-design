{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11",
    "uv": "latest"
  },
  "steps": {
    "install": {
      "inputs": [
        "...",
        { "local": true, "include": ["."] }
      ],
      "commands": [
        "uv --directory api sync --no-dev"
      ],
      "deployOutputs": [
        { "include": ["api"] }
      ]
    }
  },
  "deploy": {
    "inputs": [
      "...",
      {
        "step": "packages:mise",
        "include": ["/mise/shims", "/mise/installs"]
      }
    ],
    "startCommand": "PYTHONPATH=/app/api /app/api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
