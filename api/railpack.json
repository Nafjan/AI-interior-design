{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install": {
      "inputs": [
        "...",
        { "local": true, "include": ["."] }
      ],
      "commands": [
        "python3.11 -m pip install --upgrade pip",
        "python3.11 -m pip install --target /app/api/site-packages \"fastapi>=0.115.0\" \"uvicorn[standard]>=0.30.0\" \"python-multipart>=0.0.9\" \"pydantic>=2.9.0\" \"pydantic-settings>=2.5.0\" \"asyncpg>=0.30.0\" \"google-cloud-storage>=2.18.0\" \"arq>=0.26.0\" \"redis>=5.2.0\" \"httpx>=0.27.0\" \"pillow>=10.4.0\" \"python-dotenv>=1.0.1\" \"async-timeout>=4.0.3\""
      ],
      "deployOutputs": [
        { "include": ["api/app"] },
        { "include": ["api/site-packages"] }
      ]
    }
  },
  "deploy": {
    "startCommand": "PYTHONPATH=/app/api/site-packages:/app/api python3.11 -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
