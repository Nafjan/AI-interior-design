{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install": {
      "commands": [
        { "cmd": "pip install uv", "customName": "Install uv" },
        { "cmd": "cd api && uv sync --no-dev", "customName": "Install Python dependencies" }
      ]
    }
  },
  "deploy": {
    "startCommand": "cd /app/api && .venv/bin/uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
